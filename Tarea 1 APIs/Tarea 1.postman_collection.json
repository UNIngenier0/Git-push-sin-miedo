  "item": [
    {
      "name": "NASA - Foto del día",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status es 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Respuesta tiene title y url\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.have.property(\"title\");\r",
              "    pm.expect(jsonData).to.have.property(\"url\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://api.nasa.gov/planetary/apod?api_key=DEMO_KEY",
          "protocol": "https",
          "host": [
            "api",
            "nasa",
            "gov"
          ],
          "path": [
            "planetary",
            "apod"
          ],
          "query": [
            {
              "key": "api_key",
              "value": "DEMO_KEY"
            }
